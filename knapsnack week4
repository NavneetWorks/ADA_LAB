#include <stdio.h>
#include <stdlib.h>

struct s {
    int weight;
    int value;
    float ratio;
};

int compare(const void* a, const void* b) {
    float r1 = ((struct s*)a)->ratio;
    float r2 = ((struct s*)b)->ratio;

    if (r2 > r1) return 1;
    else if (r2 < r1) return -1;
    else return 0;
}

float fractionalKnapSnack(struct s s1[], int n, int w) {
    qsort(s1, n, sizeof(struct s), compare);

    float total = 0.0;

    for (int i = 0; i < n; i++) {
        if (w >= s1[i].weight) {
            total += s1[i].value;
            w -= s1[i].weight;
        } else {
            total += s1[i].ratio * w;
            break;
        }
    }
    return total;
}

int main() {
    int n;
    printf("Enter the size: ");
    scanf("%d", &n);

    int w;
    printf("Enter the capacity: ");
    scanf("%d", &w);

    struct s s1[n];

    for (int i = 0; i < n; i++) {
        printf("Enter weight and value: ");
        scanf("%d %d", &s1[i].weight, &s1[i].value);

        s1[i].ratio = (float)s1[i].value / s1[i].weight;
    }

    float total = fractionalKnapSnack(s1, n, w);

    printf("Total max value: %.2f\n", total);

    return 0;
}
