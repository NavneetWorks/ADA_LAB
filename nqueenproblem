
#include <stdio.h>
#include <stdlib.h>

int x[20];   // x[row] stores the column position of queen in that row

/* Check whether queen can be placed at row k, column i */
int place(int k, int i) {
    for (int j = 1; j < k; j++) {
        /* Same column or same diagonal */
        if (x[j] == i || abs(x[j] - i) == abs(j - k)) {
            return 0;
        }
    }
    return 1;
}

/* Function to print the chessboard */
void printBoard(int n) {
    printf("\nSolution:\n\n");

    for (int i = 1; i <= n; i++) {
        for (int j = 1; j <= n; j++) {
            if (x[i] == j)
                printf(" Q ");
            else
                printf(" . ");
        }
        printf("\n");
    }
}

/* Recursive function to solve N-Queens problem */
int nQueen(int k, int n) {
    for (int i = 1; i <= n; i++) {
        if (place(k, i)) {
            x[k] = i;

            if (k == n) {
                printBoard(n);
                return 1;       // Stop after finding one solution
            }

            if (nQueen(k + 1, n))
                return 1;
        }
    }

    return 0;
}

int main() {
    int n;

    printf("Enter the number of queens: ");
    scanf("%d", &n);

    if (n <= 0 || n > 20) {
        printf("Enter a value between 1 and 20.\n");
        return 0;
    }

    if (!nQueen(1, n)) {
        printf("No solution exists for %d queens.\n", n);
    }

    return 0;
}
