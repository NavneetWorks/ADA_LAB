#include <stdio.h>

#define INF 99999

void floyd(int n, int D[n][n]) {
    for (int k = 0; k < n; k++) {
        for (int i = 0; i < n; i++) {
            for (int j = 0; j < n; j++) {

                if (D[i][k] != INF && D[k][j] != INF &&
                    (D[i][k] + D[k][j] < D[i][j])) {
                    D[i][j] = D[i][k] + D[k][j];
                }
            }                                                                                                                                                                                                                                                                                        
        }
    }
}

int main() {
    int n;

    printf("Enter number of vertices: ");
    scanf("%d", &n);
    int W[n][n];
    int D[n][n];

    printf("Enter adjacency matrix:\n");
    printf("(Use %d for no direct path)\n", INF);

    for (int i = 0; i < n; i++) {
        for (int j = 0; j < n; j++) {
            int x;
            scanf("%d", &x);
            D[i][j] = x;
            W[i][j] = x;
        }
    }



    floyd(n, D);

    printf("\nFinal Shortest Path Matrix:\n");
    for (int i = 0; i < n; i++) {
        for (int j = 0; j < n; j++) {
            if (D[i][j] == INF)
                printf("INF ");
            else
                printf("%3d ", D[i][j]);
        }
        printf("\n");
    }

    return 0;
}
